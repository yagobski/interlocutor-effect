# API Keys for LLM providers
# Required to run benchmark.py, ablation_run.py, and other experiment scripts

# OpenRouter API key (for Llama 3.3 70B, Mistral Large, and other models)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# HuggingFace Hub token (for mechanistic interpretability experiments)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=hf_...

# Google Cloud Platform (for Vertex AI activation patching experiments)
# Required to run launch_vertex_job.sh and watch_vertex_job.sh
GCP_ACCOUNT=you@gmail.com
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
GCP_BUCKET=your-gcp-project-id-dlasti-ml

# Optional: AgentLeak configuration overrides
# AGENTLEAK_MODEL=gpt-4o
# AGENTLEAK_N_SCENARIOS=100
# AGENTLEAK_SEED=42
# AGENTLEAK_OUTPUT_DIR=./results
# AGENTLEAK_LOG_LEVEL=INFO
